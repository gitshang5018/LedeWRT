# IPv6支持
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=y
CONFIG_PACKAGE_ipv6helper=y

# 禁用有兼容性问题的 ksmbd
# CONFIG_PACKAGE_ksmbd-server is not set
# CONFIG_PACKAGE_luci-app-ksmbd is not set
# CONFIG_PACKAGE_kmod-fs-ksmbd is not set
# CONFIG_PACKAGE_autosamba is not set

# 必备核心组件
# CONFIG_PACKAGE_luci-app-uhttpd is not set
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y

# 基础 LuCI 主题
# CONFIG_PACKAGE_luci-theme-design is not set
CONFIG_PACKAGE_luci-theme-argon=y

# 取消编译VMware镜像
# CONFIG_TARGET_IMAGES_PAD is not set
# CONFIG_ISO_IMAGES=y

CONFIG_DEVEL=y
CONFIG_CCACHE=y

# 禁用 libwebsockets-mbedtls（4.3.2 与 mbedtls 存在 API 兼容 bug）
# CONFIG_PACKAGE_libwebsockets-mbedtls is not set
CONFIG_PACKAGE_libwebsockets-openssl=y

CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_vlmcsd=y

