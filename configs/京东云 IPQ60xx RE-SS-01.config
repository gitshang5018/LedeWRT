CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
# еҶ…еӯҳиҫғеӨ§пјҢеҸҜд»ҘдёҠзЁҚеҫ®иҝӣйҳ¶зҡ„з»„еҗ?
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-unblockneteasemusic=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-filetransfer=y
# еҸҜйҖ? йӣ…е…ёеЁңжҖ§иғҪе’ҢеҶ…еӯҳйғҪдёҚй”ҷпјҢејҖеҗ?Dockerman зҺ©е®№еҷ?
CONFIG_PACKAGE_luci-app-dockerman=y
# еӨҡж–Үд»¶зі»з»ҹж”ҜжҢ?(иҖғиҷ‘еҲ°еҸҜиғҪжҸ’еӨ–зҪ®еӯҳеӮЁ)
CONFIG_PACKAGE_kmod-fs-ntfs=y
CONFIG_PACKAGE_kmod-fs-ext4=y
# зЎ¬д»¶еҠ йҖ?(Turbo ACC & жөҒйҮҸеҲҶиҪҪ)
CONFIG_PACKAGE_kmod-ipt-offload=y
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOAD=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_FULLCONENAT=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y
CONFIG_PACKAGE_UnblockNeteaseMusic=y
CONFIG_PACKAGE_node=y
CONFIG_PACKAGE_lucky=y

# NSS Hardware Acceleration
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-drv=y
CONFIG_PACKAGE_kmod-qca-nss-drv-pppoe=y
CONFIG_PACKAGE_kmod-qca-nss-drv-bridge-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-drv-vlan-mgr=y
CONFIG_PACKAGE_kmod-qca-nss-ecm=y
