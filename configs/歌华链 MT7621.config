CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_gehua_ghl-r-001=y
# ====== WiFi: 使用 MediaTek 闭源驱动 ======
# 闭源 MT7603 驱动 (2.4G)
CONFIG_PACKAGE_kmod-mt7603e=y
# 闭源 MT76x2 驱动 (5G)
CONFIG_PACKAGE_kmod-mt76x2e=y
# 闭源驱动专属的 LuCI 无线管理界面
CONFIG_PACKAGE_luci-app-mtwifi=y
# 禁用开源 mt76 驱动，避免冲突
# CONFIG_PACKAGE_kmod-mt7603 is not set
# CONFIG_PACKAGE_kmod-mt76x2 is not set
# CONFIG_PACKAGE_kmod-mt76 is not set
# CONFIG_PACKAGE_kmod-mt76-core is not set
# CONFIG_PACKAGE_kmod-mt76-connac is not set
# CONFIG_PACKAGE_wpad-basic-mbedtls is not set
# CONFIG_PACKAGE_wpad-basic-wolfssl is not set

# 流量分载内核模块（MT7621 平台会自动启用硬件 NAT 加速）
CONFIG_PACKAGE_kmod-ipt-offload=y

# Turbo ACC 加速控制面板
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_OFFLOAD=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_FULLCONENAT=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y

# MT7621 常用实用插件 (轻量级组合)
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-filetransfer=y
CONFIG_PACKAGE_luci-app-wol=y

